# Stage 1 (genesis) + Stage 2 (bridge) + Stage 4 (serve)
# Used for Claude Sonnet calls: expert analysis, system prompt synthesis,
# bridge config generation, and API query serving.
ANTHROPIC_API_KEY=

# Stage 3 (generate) — synthetic fine-tune data generator
# Default: Z.AI GLM-4.6 (cheap at scale for ~2,600 generations per agent).
# To use a different provider, pass --api-key-env and --base-url to generate.py / simic.py.
ZAI_API_KEY=

# Optional — auth token for serve.py /query endpoint
# If unset, /query is open (local dev mode).
# API_AUTH_TOKEN=

# Optional — CORS origins for serve.py
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
